# production instance of reverse_proxy
# this caddy works in docker network with production
# database and backend instances.

# Email for Let's Encrypt expiration notices
{
	email {$CADDY_LETSENCRYPT_EMAIL}
}

{$CADDY_DOMAIN_NAME} {
	# HTTPS options:
	header Strict-Transport-Security max-age=31536000;


	# Removing some headers for improved security:
	header -Server

	rate_limit {
		# Enable distributed limitation if you have multiple Caddy nodes.
		# Works ok for one node.
		distributed

		zone static {
			match {
				method GET
				path /static/* /media/*
			}
			key {remote_host}
			events 500
			window 10s
		}

		zone dynamic {
			match {
				not path /static/* /media/*
			}
			key {remote_host}
			events 300
			window 3s
		}

		log_key
	}
	# Serve static files
	handle_path /static/* {
		# STATIC_ROOT
		root * /var/www/django/static

		file_server {
			# Staticfiles are pre-compressed in `gunicorn.sh`
			precompressed br gzip
		}
	}

	# Serve media files
	handle_path /media/* {
		# MEDIA_ROOT
		root * /var/www/django/media

		file_server
	}


  # Serve Django paths
  handle /api/* {
          reverse_proxy web:8000
  }
  handle /admin/* {
        reverse_proxy web:8000
  }


  # Serve Frontend static files
  handle {
          root * /var/www/frontend
          file_server
          try_files {path} {path}/ /index.html
  }

  handle /dozzle/* {
          reverse_proxy dozzle:8080
  }

	# Dynamically compress response with gzip when it makes sense.
	# This setting is ignored for precompressed files.
	encode gzip

	# Logs:
	log {
		output stdout
		format console
	}
}
