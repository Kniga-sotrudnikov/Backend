# ====================
# DJANGO CORE SETTINGS
# ====================
# DEBUG=TRUE: Local development
# DEBUG=FALSE: Production Deploy
DEBUG=True
SECRET_KEY=your-production-secret-key-change-this-now-minimum-50-symbols
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
CORS_ALLOWED_ORIGINS=http://localhost:5137,http://127.0.0.1:5137


# ====================
# DATABASE
# ====================
POSTGRES_DB=db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=_CHANGEME_
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Used by `pg_isready`:
PGUSER=postgres


# ====================
# EMAIL
# ====================
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@myproject.com
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=


# ====================
# CADDY WEBSERVER FOR PRODUCTION
# ====================
CADDY_DOMAIN_NAME=mydomain.ru
CADDY_LETSENCRYPT_EMAIL=some@email.com.no


# ====================
# CELERY & REDIS
# ====================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0